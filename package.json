{
  "name": "playlistify",
  "version": "1.0.0",
  "description": "YouTube playlist manager and downloader",
  "main": ".webpack/main/index.js",
  "scripts": {
    "prestart": "node src/patch-warning.js",
    "start": "electron-forge start",
    "dev": "node src/patch-warning.js && cross-env NODE_ENV=development electron-forge start",
    "package": "node src/patch-warning.js && electron-forge package",
    "make": "node src/patch-warning.js && electron-forge make",
    "publish": "node src/patch-warning.js && electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "lint:fix": "eslint --ext .ts,.tsx . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "keywords": [
    "electron",
    "youtube",
    "playlist",
    "downloader"
  ],
